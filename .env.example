# Optional. Enables Gemini-backed AI responses. Leave empty to use local fallback guidance.
GEMINI_API_KEY=

# Optional. Directory for local JSON data. Defaults to data/ locally and /tmp/jobpilot on Vercel.
JOBPILOT_DATA_DIR=

# Optional. Daily AI action limits for visitor-cookie and hashed-IP quota subjects.
JOBPILOT_DAILY_AI_ACTION_LIMIT=3
JOBPILOT_DAILY_AI_IP_LIMIT=3

# Recommended for public demos. Use a private random value so hashed IP quota subjects are not predictable.
JOBPILOT_ABUSE_SALT=
